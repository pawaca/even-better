{
  "name": "even-better",
  "version": "0.1.0",
  "description": "Mirror terminal coding-agent sessions to Even Realities G2 glasses (even-terminal protocol compatible)",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "license": "MIT",
  "author": "pawaca",
  "repository": {
    "type": "git",
    "url": "https://github.com/pawaca/even-better"
  },
  "keywords": [
    "even-realities",
    "g2-glasses",
    "ar-glasses",
    "claude-code",
    "codex",
    "coding-agent",
    "terminal",
    "sse",
    "herdr",
    "cmux"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test scripts/test-*.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
